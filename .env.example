# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=https://classified.example.com
NEXT_PUBLIC_APP_NAME="Classified Marketplace"
NEXT_PUBLIC_DEFAULT_LOCALE=en
NODE_ENV=development

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ============================================
# FIREBASE — CLIENT (public)
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ============================================
# FIREBASE — ADMIN (server only)
# Use either FIREBASE_SERVICE_ACCOUNT_KEY (full JSON, base64-encoded)
# or the three discrete fields below.
# ============================================
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ============================================
# RECAPTCHA (Firebase Phone Auth + form protection)
# ============================================
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ============================================
# GOOGLE MAPS / PLACES
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# ADMIN ACCESS (comma-separated emails)
# ============================================
ADMIN_EMAILS=admin@example.com

# ============================================
# ADVERTISING & ANALYTICS
# ============================================
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ============================================
# EMAIL (CV email delivery, transactional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="Classified Marketplace"

# ============================================
# PAYMENT GATEWAYS (manual verification for now)
# ============================================
# Saudi Arabia
STC_PAY_MERCHANT_ID=
ALINMA_PAY_MERCHANT_ID=
BARQ_MERCHANT_ID=

# Bangladesh
BKASH_MERCHANT_NUMBER=
NAGAD_MERCHANT_NUMBER=

# Crypto (BSC USDT)
USDT_BSC_WALLET_ADDRESS=

# Future-ready
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
MOYASAR_API_KEY=

# ============================================
# AUTOMATION (n8n future integration)
# ============================================
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ============================================
# RATE LIMITING (Upstash Redis — optional, recommended)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
